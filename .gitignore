Homestead.yaml

# --- Carpetas de Dependencias y Build ---
/node_modules
/vendor
/public/build
/public/hot
/public/storage

# --- IDEs y Herramientas ---
/.fleet
/.idea
/.nova
/.vscode
/.zed
